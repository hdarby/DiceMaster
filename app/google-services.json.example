{
  "_comment": "Copy this file to google-services.json and fill in the values from your Firebase project.",
  "_instructions": [
    "1. Go to https://console.firebase.google.com and create (or open) your project.",
    "2. Add an Android app with package name: com.hdarby.dicemaster",
    "3. Download the generated google-services.json and place it in the app/ directory.",
    "4. The real google-services.json is listed in app/.gitignore — never commit it."
  ],
  "project_info": {
    "project_number": "YOUR_PROJECT_NUMBER",
    "project_id": "YOUR_PROJECT_ID",
    "storage_bucket": "YOUR_PROJECT_ID.appspot.com"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "1:YOUR_PROJECT_NUMBER:android:YOUR_APP_HASH",
        "android_client_info": {
          "package_name": "com.hdarby.dicemaster"
        }
      },
      "oauth_client": [],
      "api_key": [
        {
          "current_key": "YOUR_API_KEY"
        }
      ],
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": []
        }
      }
    }
  ],
  "configuration_version": "1"
}

